{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/team-logos/:path*", "destination": "/api/index" },
    { "source": "/chat", "destination": "/api/index" },
    { "source": "/start", "destination": "/api/index" },
    { "source": "/players", "destination": "/api/index" },
    { "source": "/chart_summary/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
