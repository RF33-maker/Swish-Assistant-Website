{
  "version": 2,
  "buildCommand": "vite build && node_modules/.bin/esbuild api/_source.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/team-logos/:path*", "destination": "/api/index" },
    { "source": "/chat", "destination": "/api/index" },
    { "source": "/start", "destination": "/api/index" },
    { "source": "/players", "destination": "/api/index" },
    { "source": "/chart_summary/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
